<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="fun.cyhgraph.mapper.AddressBookMapper">

    <update id="udpate">
        update address_book
        <set>
            <if test="consignee != null">
                consignee = #{consignee},
            </if>
            <if test="gender != null">
                gender = #{gender},
            </if>
            <if test="phone != null">
                phone = #{phone},
            </if>
            <if test="detail != null">
                detail = #{detail},
            </if>
            <if test="label != null">
                label = #{label},
            </if>
            <if test="isDefault != null">
                is_default = #{isDefault},
            </if>
            <if test="provinceCode != null">
                province_code = #{provinceCode},
            </if>
            <if test="provinceName != null">
                province_name = #{provinceName},
            </if>
            <if test="cityCode != null">
                city_code = #{cityCode},
            </if>
            <if test="cityName != null">
                city_name = #{cityName},
            </if>
            <if test="districtCode != null">
                district_code = #{districtCode},
            </if>
            <if test="districtName != null">
                district_name = #{districtName},
            </if>
            <if test="campusNodeId != null">
                campus_node_id = #{campusNodeId},
            </if>
            <if test="isPublic != null">
                is_public = #{isPublic},
            </if>
        </set>
        where id = #{id}
    </update>

    <select id="getUserAddress" resultType="fun.cyhgraph.entity.AddressBook">
        select * from address_book
        <where>
            <choose>
                <when test="isDefault != null">
                    and user_id = #{userId}
                    and is_default = #{isDefault}
                </when>
                <otherwise>
                    and (user_id = #{userId} or is_public = 1)
                </otherwise>
            </choose>
            <if test="phone != null">
                and phone = #{phone}
            </if>
        </where>
        order by is_default desc, is_public asc, id desc
    </select>
</mapper>
